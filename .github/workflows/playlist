name: Bilibili Playlist Subtitles Once

on:
  workflow_dispatch:
    inputs:
      url:
        description: "B站合集/多P链接"
        required: true
        default: "https://www.bilibili.com/video/BV1UjApe3E84?spm_id_from=333.788.videopod.sections&vd_source=1333df6f11f8b384c9d06647ecc4b5e8"
        type: string
      langs:
        description: "字幕语言（逗号分隔/可正则）"
        required: false
        default: "zh.*,zh-CN,zh-Hans,.*orig"
        type: string
      user_agent:
        description: "可选：浏览器UA"
        required: false
        default: ""
        type: string
      output_file:
        description: "合并后文件名"
        required: false
        default: "playlist_subs_merged.txt"
        type: string

permissions:
  contents: write

jobs:
  bilibili_playlist_subs_once:
    runs-on: ubuntu-latest
    env:
      YTDLP_COOKIES_TXT: ${{ secrets.YTDLP_COOKIES_TXT }}

    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          persist-credentials: true
          fetch-depth: 0
          ref: main

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "20"

      - name: Install ffmpeg
        shell: bash
        run: |
          sudo apt-get update
          sudo apt-get install -y ffmpeg
          ffmpeg -version

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"
          cache: "pip"

      - name: Install dependencies
        shell: bash
        run: |
          python -m pip install -U pip
          pip install -U yt-dlp

      - name: Write cookies.txt (optional)
        if: ${{ env.YTDLP_COOKIES_TXT != '' }}
        shell: bash
        run: |
          printf '%s' "$YTDLP_COOKIES_TXT" | tr -d '\r' > cookies.txt

      - name: Prepare folders
        shell: bash
        run: |
          mkdir -p work/playlist_subs
          mkdir -p subs/merged

      - name: Download subtitles for all playlist items
        env:
          URL: ${{ inputs.url }}
          LANGS: ${{ inputs.langs }}
          UA: ${{ inputs.user_agent }}
        shell: bash
        run: |
          set -euo pipefail

          UA_ARGS=()
          if [[ -n "${UA}" ]]; then
            UA_ARGS=(--user-agent "${UA}")
          fi

          COOKIE_ARGS=()
          if [[ -f cookies.txt ]]; then
            COOKIE_ARGS=(--cookies cookies.txt)
          fi

          yt-dlp \
            --yes-playlist \
            --ignore-errors \
            --no-overwrites \
            --skip-download \
            --write-subs \
            --write-auto-subs \
            --sub-langs "${LANGS}" \
            --sub-format "srt/vtt/best" \
            --convert-subs srt \
            --js-runtimes node --remote-components ejs:github \
            -o "work/playlist_subs/%(playlist_index)03d_%(title).200s_%(id)s.%(ext)s" \
            "${COOKIE_ARGS[@]}" \
            "${UA_ARGS[@]}" \
            "${URL}"

      - name: Merge subtitles into one text file
        env:
          OUTPUT_FILE: ${{ inputs.output_file }}
        shell: bash
        run: |
          python - <<'PY'
          import os
          import re
          from pathlib import Path

          in_dir = Path("work/playlist_subs")
          out_dir = Path("subs/merged")
          out_dir.mkdir(parents=True, exist_ok=True)
          output_file = out_dir / os.environ["OUTPUT_FILE"]

          subtitle_files = sorted(
              [p for p in in_dir.glob("*") if p.suffix.lower() in {".srt", ".vtt", ".txt", ".lrc"}]
          )

          def clean_lines(text: str, suffix: str):
              lines = text.splitlines()
              out = []
              for line in lines:
                  s = line.strip()
                  if not s:
                      continue
                  if suffix == ".srt":
                      if re.fullmatch(r"\d+", s):
                          continue
                      if "-->" in s:
                          continue
                  elif suffix == ".vtt":
                      if s.upper() == "WEBVTT":
                          continue
                      if "-->" in s:
                          continue
                  elif suffix == ".lrc":
                      s = re.sub(r"\[[0-9]{1,2}:[0-9]{2}(?:\.[0-9]{1,3})?\]", "", s).strip()
                      if not s:
                          continue
                  out.append(s)
              return out

          with output_file.open("w", encoding="utf-8") as f:
              f.write("Bilibili Playlist Subtitles Merged\n\n")
              if not subtitle_files:
                  f.write("No subtitle files found.\n")
              for p in subtitle_files:
                  title = p.stem
                  text = p.read_text(encoding="utf-8", errors="ignore")
                  cleaned = clean_lines(text, p.suffix.lower())

                  f.write("=" * 80 + "\n")
                  f.write(f"{title}\n")
                  f.write("=" * 80 + "\n\n")
                  if cleaned:
                      f.write("\n".join(cleaned))
                      f.write("\n\n")
                  else:
                      f.write("[Empty or unsupported subtitle content]\n\n")

          print(output_file)
          PY

      - name: Commit & push merged subtitles
        shell: bash
        run: |
          set -euo pipefail

          if [[ -z "$(git status --porcelain subs)" ]]; then
            echo "No changes under subs/. Skip commit."
            exit 0
          fi

          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"

          git add subs
          git commit -m "Add merged playlist subtitles (one-off)" || exit 0

          max_attempts=6
          attempt=1

          while (( attempt <= max_attempts )); do
            echo "Push attempt ${attempt}/${max_attempts}"

            if ! git pull --rebase origin main; then
              git rebase --abort || true
              echo "Rebase failed."
              exit 1
            fi

            if git push origin HEAD:main; then
              echo "Push succeeded."
              exit 0
            fi

            echo "Push failed because remote main moved. Retrying..."
            sleep $(( attempt * 2 ))
            attempt=$(( attempt + 1 ))
          done

          echo "Push failed after ${max_attempts} attempts."
          exit 1
